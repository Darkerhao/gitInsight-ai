{
  "name": "gitinsight-ai",
  "version": "3.5.0",
  "author": {
    "name": "DarkerHao",
    "email": "1726348482@qq.com"
  },
  "description": "AI daily report assistant for Git repositories",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "node scripts/dist-edition.mjs --dir",
    "dist": "node scripts/dist-edition.mjs",
    "dist:lite": "node scripts/dist-edition.mjs --edition lite",
    "dist:standard": "node scripts/dist-edition.mjs --edition standard",
    "dist:win": "node scripts/dist-edition.mjs --win",
    "dist:win:lite": "node scripts/dist-edition.mjs --edition lite --win",
    "dist:win:standard": "node scripts/dist-edition.mjs --edition standard --win",
    "dist:mac": "node scripts/dist-edition.mjs --mac",
    "dist:mac:lite": "node scripts/dist-edition.mjs --edition lite --mac",
    "dist:mac:standard": "node scripts/dist-edition.mjs --edition standard --mac",
    "dist:linux": "node scripts/dist-edition.mjs --linux",
    "dist:linux:lite": "node scripts/dist-edition.mjs --edition lite --linux",
    "dist:linux:standard": "node scripts/dist-edition.mjs --edition standard --linux",
    "start": "electron .",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "release:tag": "node scripts/release-tag.mjs"
  },
  "dependencies": {
    "@vueuse/core": "^13.5.0",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.6.2",
    "element-plus": "^2.10.4",
    "gsap": "^3.15.0",
    "lucide-vue-next": "^0.548.0",
    "simple-git": "^3.27.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@swc/core": "^1.13.5",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^37.2.6",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vue-tsc": "^2.2.12"
  }
}
